<VirtualHost *:80>
    ServerName {{ apache_vhost_servername }}
    DocumentRoot {{ apache_docroot }}

    <Directory {{ apache_docroot }}>
        Options Indexes FollowSymLinks
        AllowOverride All
        Require all granted
        DirectoryIndex index.php index.html
    </Directory>

{% if ansible_os_family == 'Debian' %}
    ErrorLog  ${APACHE_LOG_DIR}/{{ apache_vhost_servername }}_error.log
    CustomLog ${APACHE_LOG_DIR}/{{ apache_vhost_servername }}_access.log combined
{% else %}
    ErrorLog  /var/log/httpd/{{ apache_vhost_servername }}_error.log
    CustomLog /var/log/httpd/{{ apache_vhost_servername }}_access.log combined
{% endif %}
</VirtualHost>
